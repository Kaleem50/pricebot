# ================================================================
# PriceBot Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git — only .env.example is committed.
# ================================================================

# ── Anthropic ────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-


# ── Supabase ─────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ
SUPABASE_SERVICE_ROLE_KEY=eyJ


# ── Security Keys ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=
JWT_SECRET=


# ── App ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development


# ── Stripe (Week 2) ──────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STARTER_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_


# ── Amazon SP-API (Week 2) ───────────────────────────────────────
# Get from: Seller Central → Developer Console
AMAZON_APP_CLIENT_ID=amzn1.application-oa2-client.
AMAZON_APP_CLIENT_SECRET=


# ── Etsy Open API (Week 5) ───────────────────────────────────────
# Get from: etsy.com/developers → Your App → Keystring
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=


# ── Transactional Email — Resend (Week 6) ────────────────────────
# Get from: resend.com → API Keys
# Used for: price-change notifications to sellers + CRITICAL alerts to operator
RESEND_API_KEY=re_
NOTIFICATIONS_FROM_EMAIL=PriceBot <notifications@pricebot.io>


# ── Operator Config (Week 6) ─────────────────────────────────────
# OPERATOR_EMAIL: receives CRITICAL alert emails and beta request notifications
# OPERATOR_SECRET: secret header value for GET /beta/requests (generate with: openssl rand -hex 24)
OPERATOR_EMAIL=your@email.com
OPERATOR_SECRET=